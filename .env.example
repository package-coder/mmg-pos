# Copy this file to pos-api/.env and fill in the values before running docker-compose

# ── Flask API ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# APP_ENV controls which database connection is used
# Values: local-development | development | internal-production | production
APP_ENV=internal-production

DATABASE=pos

# Used by internal-production (docker-compose.yml) — points to the mongo container
LOCAL_DATABASE_URL=mongodb://mongo:27017

# Used by production (docker-compose.prod.yml) — remote Atlas or EC2 MongoDB URI
REMOTE_DATABASE_URL=mongodb+srv://<user>:<pass>@<host>/<db>?authSource=<db>

# ── Sync service ───────────────────────────────────────────────────────────────
# Both URLs are required by the sync service regardless of environment
# LOCAL_DATABASE_URL is set above; override REMOTE_DATABASE_URL here if needed

# ── Proxy service ──────────────────────────────────────────────────────────────
# LOCAL_SERVER_URL is injected by docker-compose — no need to set it here
# CLOUD_SERVER_URL is only used if you re-enable the internet-failover logic in proxy/app.py
# CLOUD_SERVER_URL=http://<ec2-ip>:5000
