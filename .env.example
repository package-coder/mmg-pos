# Copy this file to pos-api/.env and fill in secrets before running docker-compose.
# All three backend services (server, proxy, sync) read from pos-api/.env.

# ── Flask API ──────────────────────────────────────────────────────────────────
# Controls which database connection is used
# Values: local-development | development | internal-production | production
APP_ENV=internal-production

# Long random string — used to sign JWTs. Change this for every deployment.
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# MongoDB database name
DATABASE=pos

# Flask port — must match the port in docker-compose.yml (server: 8001->5100)
PORT=5100

# ── Database ───────────────────────────────────────────────────────────────────
# Local MongoDB — used by internal-production (points to the mongo container)
LOCAL_DATABASE_URL=mongodb://mongo:27017

# Remote MongoDB Atlas or EC2 — used by production and the sync service
# Leave as placeholder if cloud sync is not needed (sync will crash-loop but core POS works)
REMOTE_DATABASE_URL=mongodb+srv://<user>:<pass>@<host>/<db>?authSource=<db>

# ── Proxy ──────────────────────────────────────────────────────────────────────
# Injected automatically by docker-compose — no need to set here for Docker deployments
# Required when running proxy outside Docker
# LOCAL_SERVER_URL=http://localhost:5100

# Cloud server fallback — currently unused (failover logic is commented out in proxy/app.py)
# CLOUD_SERVER_URL=http://<ec2-ip>:5000
