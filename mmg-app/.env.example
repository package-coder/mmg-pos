# ── App ────────────────────────────────────────────────────────────────────────
# Controls which routes and features are enabled
# Values: development | internal-production | production | staging
VITE_APP_ENV=internal-production

# Version string shown on the login screen and POS page
VITE_APP_VERSION="MMG POS v0.1.0"

# Router basename — leave as / unless the app is served from a sub-path
VITE_APP_BASE_NAME=/

# ── API connection ─────────────────────────────────────────────────────────────
# Non-production: browser builds the URL as http://<window.hostname>:<PORT>
# Set to the host-mapped proxy port (8002 in docker-compose, 5001 in local dev)
VITE_APP_SERVER_PORT=8002

# Production only: full URL to the API / proxy
# Used when VITE_APP_ENV=production; ignored otherwise
VITE_APP_SERVER_URL=http://<server-ip>:8002
